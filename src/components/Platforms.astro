---
---

<section id="platforms" class="relative py-32 lg:py-40 px-6 lg:px-8">
  <!-- Section divider -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-transparent via-neutral-400/20 to-transparent"></div>
  
  <div class="max-w-6xl mx-auto">
    <!-- Section label -->
    <p class="text-xs uppercase tracking-extra-wide text-neutral-300 mb-12 text-center">
      Platform Divisions
    </p>
    
    <!-- Intro -->
    <p class="text-xl md:text-2xl text-neutral-200 text-center max-w-3xl mx-auto mb-20 leading-relaxed">
      Seityl operates through specialized platforms designed for 
      specific operational domains.
    </p>
    
    <!-- Platforms grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-neutral-500/20">
      <!-- Seityl Systems -->
      <div class="bg-background p-8 lg:p-12 group">
        <div class="w-8 h-px bg-accent mb-6"></div>
        <h3 class="text-lg font-medium text-white mb-3 tracking-wide">SEITYL SYSTEMS</h3>
        <p class="text-sm text-neutral-200 mb-6 leading-relaxed">
          Core infrastructure and AI capabilities. The foundation upon which all Seityl platforms operate.
        </p>
        <div class="flex items-center gap-2 text-xs text-neutral-400">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          Infrastructure Layer
        </div>
      </div>
      
      <!-- Seityl Trade -->
      <div class="bg-background p-8 lg:p-12 group">
        <div class="w-8 h-px bg-accent mb-6"></div>
        <h3 class="text-lg font-medium text-white mb-3 tracking-wide">SEITYL TRADE</h3>
        <p class="text-sm text-neutral-200 mb-6 leading-relaxed">
          Customs automation, port intelligence, and logistics orchestration for modern trade operations.
        </p>
        <div class="flex items-center gap-2 text-xs text-neutral-400">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          Operational Platform
        </div>
      </div>
      
      <!-- Seityl Grants -->
      <div class="bg-background p-8 lg:p-12 group">
        <div class="w-8 h-px bg-accent mb-6"></div>
        <h3 class="text-lg font-medium text-white mb-3 tracking-wide">SEITYL GRANTS</h3>
        <p class="text-sm text-neutral-200 mb-6 leading-relaxed">
          Intelligent funding distribution, compliance tracking, and grant lifecycle management systems.
        </p>
        <div class="flex items-center gap-2 text-xs text-neutral-400">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          Operational Platform
        </div>
      </div>
    </div>
    
    <!-- Underlying principle -->
    <div class="mt-20 text-center">
      <p class="text-sm text-neutral-300 max-w-2xl mx-auto">
        All platforms share a common architecture: autonomous, sovereign, 
        and designed to operate without dependency.
      </p>
    </div>
  </div>
</section>

---
---

<section class="relative py-48 lg:py-64 px-6 lg:px-8">
  <!-- Section divider -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-transparent via-neutral-400/20 to-transparent"></div>
  
  <!-- Subtle geometric accent -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[800px] aspect-square opacity-[0.015] pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 100 100" class="w-full h-full" fill="none" stroke="currentColor" stroke-width="0.25" aria-hidden="true">
      <!-- Concentric system rings -->
      <circle cx="50" cy="50" r="20"/>
      <circle cx="50" cy="50" r="30"/>
      <circle cx="50" cy="50" r="40"/>
      <!-- Structural cross -->
      <line x1="50" y1="10" x2="50" y2="90"/>
      <line x1="10" y1="50" x2="90" y2="50"/>
      <!-- Diagonal structure -->
      <line x1="22" y1="22" x2="78" y2="78"/>
      <line x1="78" y1="22" x2="22" y2="78"/>
    </svg>
  </div>
  
  <div class="relative max-w-4xl mx-auto">
    <!-- Section label -->
    <h2 class="text-xs uppercase tracking-extra-wide text-neutral-300 mb-12 text-center">
      Direction
    </h2>
    
    <!-- Statement -->
    <div class="space-y-8">
      <p class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-light leading-relaxed text-center px-4">
        SEITYL operates systems for <span class="text-white">infrastructure</span>, 
        <span class="text-white">logistics</span>, <span class="text-white">trade</span>, 
        and <span class="text-white">enterprise</span>.
      </p>
      
      <p class="text-lg text-neutral-200 text-center max-w-2xl mx-auto leading-relaxed">
        Built for reliability, structure, and precision at scale.
      </p>
    </div>
    
    <!-- Values -->
    <div class="mt-20 flex flex-col md:flex-row items-center justify-center gap-12 md:gap-16">
      <div class="text-center">
        <p class="text-xs uppercase tracking-extra-wide text-neutral-300 mb-2">Autonomy</p>
        <p class="text-sm text-neutral-400">Self-directed operation</p>
      </div>
      <div class="text-center">
        <p class="text-xs uppercase tracking-extra-wide text-neutral-300 mb-2">Sovereignty</p>
        <p class="text-sm text-neutral-400">Complete data control</p>
      </div>
      <div class="text-center">
        <p class="text-xs uppercase tracking-extra-wide text-neutral-300 mb-2">Intelligence</p>
        <p class="text-sm text-neutral-400">Decision-capable logic</p>
      </div>
    </div>
  </div>
</section>
